{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug logs_report(bucket_name)",
      "type": "debugpy",
      "request": "launch",
      "module": "lambdas.log_processor.logs_processor",
      "python": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "local-log-processor",
        "--local-s3-output-dir",
        "docker/log-processor-s3-database",
        "--summary-output",
        "frontend/public/data/log-processor/data.json"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "S3_LOGS_BUCKET": "${input:logsBucketName}"
      },
      "preLaunchTask": "Prepare logs_report Debug",
      "justMyCode": true
    }
  ],
  "inputs": [
    {
      "id": "logsBucketName",
      "type": "promptString",
      "description": "S3 bucket containing CloudFront log objects",
      "default": "chrispsheehan.com.logs"
    }
  ]
}
