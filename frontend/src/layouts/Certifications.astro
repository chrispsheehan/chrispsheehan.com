---
import Certifications from "../components/Certifications";
---

<style is:global>
  .cert-carousel {
    position: relative;
  }

  .cert-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    justify-content: center;
    gap: 2rem;
  }

  .cert-grid > a {
    display: block;
    max-width: 220px;
    width: auto;
    text-align: center;
    margin: 0 auto;
    justify-self: center;
    padding: 0.5rem;
    border-radius: 1rem;
    background: var(--color-cert-card);
    border: 1px solid var(--color-cert-card-border);
    -webkit-tap-highlight-color: transparent;
    transition:
      transform 0.2s ease,
      background 0.2s ease,
      box-shadow 0.2s ease;
  }

  .cert-grid > a.cert-card--embed {
    padding: 0;
    background: transparent;
    border: none;
    box-shadow: none;
  }

  .cert-grid > a.cert-card--embed:hover {
    background: transparent;
    box-shadow: none;
  }

  .cert-grid > a:hover .cert-img-wrapper {
    transform: translateY(-2px);
  }

  .cert-grid > a:hover .cert-embed-wrapper {
    transform: translateY(-2px);
  }

  .cert-grid > a:hover {
    background: var(--color-cert-card-hover);
    box-shadow: var(--shadow-cert-hover);
  }

  .cert-grid > a:focus-visible {
    outline: 2px solid var(--color-hover);
    outline-offset: 2px;
  }

  .cert-img-wrapper {
    width: 150px;
    aspect-ratio: 1 / 1;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: 1rem;
    background: transparent;
    transition:
      background 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s ease;
  }

  .cert-embed-wrapper {
    width: 200px;
    min-height: 260px;
    margin: 0 auto;
    border-radius: 0.75rem;
    background: var(--color-cert-embed-bg);
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    transition: transform 0.2s ease;
  }

  .cert-embed-wrapper > div {
    width: 200px;
    min-height: 260px;
  }

  .cert-embed-wrapper iframe {
    border: 0;
    display: block;
    margin: 0 auto;
  }

  .cert-img-wrapper img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
  }

  .cert-carousel__pagination {
    display: none;
    justify-content: center;
    align-items: center;
    gap: 0.45rem;
    margin-top: 0.85rem;
  }

  .cert-carousel__dot {
    appearance: none;
    border: 0;
    width: 0.5rem;
    height: 0.5rem;
    padding: 0;
    border-radius: 999px;
    background: rgba(185, 242, 200, 0.28);
    cursor: pointer;
    transition:
      transform 0.2s ease,
      background 0.2s ease,
      width 0.2s ease;
  }

  .cert-carousel__dot--active {
    width: 1.35rem;
    background: var(--color-heading);
  }

  @media (max-width: 1000px) {
    .cert-carousel::after {
      content: "";
      position: absolute;
      top: 0;
      right: 0;
      width: 3.5rem;
      height: calc(100% - 1.4rem);
      pointer-events: none;
      background: linear-gradient(
        270deg,
        rgba(11, 25, 20, 0.9) 0%,
        rgba(11, 25, 20, 0) 100%
      );
    }

    .cert-grid {
      display: flex;
      flex-wrap: nowrap;
      gap: 1rem;
      justify-content: flex-start;
      overflow-x: auto;
      overscroll-behavior-x: contain;
      padding: 0 0 0.35rem 0;
      scroll-snap-type: x mandatory;
      scroll-padding-left: 0;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .cert-grid::-webkit-scrollbar {
      display: none;
    }

    .cert-grid > a {
      display: flex;
      flex: 0 0 100%;
      justify-content: center;
      width: 100%;
      max-width: 100%;
      padding: 0.35rem;
      scroll-snap-align: start;
    }

    .cert-img-wrapper {
      width: 100%;
      max-width: 120px;
    }

    .cert-embed-wrapper {
      width: 188px;
      min-height: 224px;
    }

    .cert-embed-wrapper > div {
      transform: scale(0.8);
      transform-origin: top center;
    }

    .cert-carousel__pagination {
      display: flex;
    }
  }
</style>

<section id="certifications">
  <p class="section-eyebrow">Certifications</p>
  <h2>Supporting credentials in AWS, Terraform, and delivery tooling.</h2>
  <p class="section-intro">
    Useful supporting proof, but secondary to the platform and delivery work
    above.
  </p>
  <Certifications client:load />
</section>
