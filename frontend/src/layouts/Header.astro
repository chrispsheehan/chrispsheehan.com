---
const { baseDomain } = Astro.props;
const githubProfile = "https://github.com/chrispsheehan";
---

<header>
  <nav>
    <div class="nav-left">
      <span class="logo">{baseDomain}</span>
    </div>

    <div class="nav-links" id="nav-links">
      <a href="#about-me" class="button">About</a>
      <a href="#certifications" class="button">Certifications</a>
      <a href="#this-site" class="button">This Site</a>
    </div>

    <!-- Mobile menu -->
    <div class="mobile-overlay" id="mobile-overlay" aria-hidden="true">
      <div class="mobile-menu-panel">
        <div class="mobile-menu-header">
          <span class="mobile-menu-title">Menu</span>
          <button
            class="mobile-close"
            type="button"
            aria-label="Close menu"
            onclick="hideMenu()"></button>
        </div>

        <div class="mobile-menu-links">
          <p class="mobile-menu-section">Sections</p>
          <a href="#about-me" class="overlay-button" onclick="hideMenu()"
            >About</a
          >
          <a href="#certifications" class="overlay-button" onclick="hideMenu()"
            >Certifications</a
          >
          <a href="#this-site" class="overlay-button" onclick="hideMenu()"
            >This Site</a
          >
        </div>

        <div class="mobile-menu-links mobile-menu-links--profiles">
          <p class="mobile-menu-section">Profiles</p>
          <div class="mobile-profile-grid">
            <a
              href="https://www.linkedin.com/in/chrispsheehan"
              class="mobile-profile-link"
              target="_blank"
              rel="noopener noreferrer"
              onclick="hideMenu()"
            >
              <img src="/assets/social/linkedin.png" alt="" aria-hidden="true" />
              <span>LinkedIn</span>
            </a>
            <a
              href={githubProfile}
              class="mobile-profile-link"
              target="_blank"
              rel="noopener noreferrer"
              onclick="hideMenu()"
            >
              <img src="/assets/social/github.png" alt="" aria-hidden="true" />
              <span>GitHub</span>
            </a>
            <a
              href="https://registry.terraform.io/namespaces/chrispsheehan"
              class="mobile-profile-link"
              target="_blank"
              rel="noopener noreferrer"
              onclick="hideMenu()"
            >
              <img src="/assets/social/terraform.png" alt="" aria-hidden="true" />
              <span>Terraform</span>
            </a>
            <a
              href="https://www.credly.com/users/chris-sheehan.b081233e/badges/credly"
              class="mobile-profile-link"
              target="_blank"
              rel="noopener noreferrer"
              onclick="hideMenu()"
            >
              <img src="/assets/social/credly.png" alt="" aria-hidden="true" />
              <span>Credly</span>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Burger icon -->
    <button
      class="burger"
      id="burger"
      type="button"
      aria-label="Toggle menu"
      aria-controls="mobile-overlay"
      aria-expanded="false"
      onclick="toggleMenu()"></button>
  </nav>

  <script type="module">
    import "/scripts/mobileMenu.js";
  </script>

  <style>
    nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      width: 100%;
      box-sizing: border-box;
      padding: 8px 24px;
      background: var(--color-background-dark);
      position: relative;
      z-index: 100;
    }

    .nav-left .logo {
      color: var(--color-heading);
      font-weight: bold;
      font-size: 1rem;
    }

    .nav-links {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    .button {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 16px;
      color: var(--color-text);
      background: var(--color-surface);
      text-decoration: none;
      border-radius: 6px;
      font-weight: bold;
      font-size: 0.95rem;
      border: 1px solid var(--color-border-strong);
      cursor: pointer;
      min-height: 32px;
      transition:
        background 0.2s ease,
        color 0.2s ease,
        transform 0.2s ease;
    }

    .button:hover {
      background: var(--color-surface-2);
      color: var(--color-heading);
      transform: translateY(-1px);
    }

    .burger {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      position: absolute;
      right: 32px;
      top: 50%;
      transform: translateY(-50%);
      z-index: 1100;
      font-size: 35px;
      color: var(--color-heading);
    }

    .burger::before {
      content: "☰";
    }

    .burger.show {
      opacity: 0;
      pointer-events: none;
    }

    .mobile-overlay {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 1000;
      background: rgba(11, 25, 20, 0.8);
      backdrop-filter: blur(4px);
      padding: 16px;
      box-sizing: border-box;
      justify-content: flex-end;
      align-items: stretch;
    }

    body.no-scroll,
    html.no-scroll {
      overflow: hidden !important;
      height: 100%;
      touch-action: none;
      overscroll-behavior: none;
    }

    .mobile-overlay.show {
      display: flex;
    }

    .mobile-menu-panel {
      width: min(520px, 100%);
      margin: 0 auto;
      max-height: calc(100dvh - 32px);
      overflow: auto;
      border-radius: 1rem;
      background: var(--color-background-dark);
      border: 1px solid var(--color-border-strong);
      padding: 16px;
      box-sizing: border-box;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .mobile-menu-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .mobile-menu-title {
      color: var(--color-heading);
      font-weight: 700;
      font-size: 1rem;
      letter-spacing: 0.03em;
    }

    .mobile-close {
      border: 1px solid var(--color-border-strong);
      background: var(--color-surface);
      color: var(--color-heading);
      border-radius: 8px;
      width: 40px;
      height: 40px;
      cursor: pointer;
      font-size: 22px;
      line-height: 1;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .mobile-close::before {
      content: "✕";
    }

    .mobile-menu-links {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .mobile-menu-section {
      margin: 0;
      color: var(--color-heading);
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .overlay-button {
      padding: 12px 16px;
      font-size: 1.1rem;
      background: var(--color-surface);
      color: var(--color-text);
      text-decoration: none;
      border-radius: 8px;
      font-weight: bold;
      border: 1px solid var(--color-border-strong);
    }

    .overlay-button:hover {
      background: var(--color-surface-2);
      color: var(--color-heading);
    }

    .mobile-profile-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .mobile-profile-link {
      display: flex;
      align-items: center;
      gap: 10px;
      min-height: 56px;
      padding: 12px 14px;
      border-radius: 12px;
      border: 1px solid var(--color-border-strong);
      background: var(--color-surface);
      color: var(--color-text);
      text-decoration: none;
      font-weight: 700;
      transition:
        background 0.2s ease,
        color 0.2s ease,
        transform 0.2s ease;
    }

    .mobile-profile-link:hover {
      background: var(--color-surface-2);
      color: var(--color-heading);
      transform: translateY(-1px);
    }

    .mobile-profile-link img {
      width: 22px;
      height: 22px;
      min-width: 22px;
      min-height: 22px;
      max-width: 22px;
      max-height: 22px;
      inline-size: 22px;
      block-size: 22px;
      flex: 0 0 22px;
      object-fit: contain;
      display: block;
    }

    @media (max-width: 1250px) and (min-width: 1001px) {
      .nav-links {
        gap: 8px;
      }

      .button {
        padding: 6px 10px;
        font-size: 0.88rem;
        min-height: 30px;
      }
    }

    @media (max-width: 1000px) {
      .burger {
        display: block;
      }

      .nav-links {
        display: none;
      }

      nav {
        padding: 10px 16px;
      }

      .mobile-menu-panel {
        padding: 14px;
      }

      .mobile-profile-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (min-width: 1000px) {
      .button:focus-visible,
      .overlay-button:focus-visible,
      .burger:focus-visible,
      .mobile-close:focus-visible {
        outline: 2px solid var(--color-hover);
        outline-offset: 2px;
      }
    }

    .button:focus-visible,
    .overlay-button:focus-visible,
    .burger:focus-visible,
    .mobile-close:focus-visible {
      outline: 2px solid var(--color-hover);
      outline-offset: 2px;
    }
  </style>
</header>
