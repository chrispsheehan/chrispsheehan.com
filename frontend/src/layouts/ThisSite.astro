---
import Visits from "../components/Visits";

const { githubRepo } = Astro.props;
---

<section id="this-site">
  <div class="section-heading" data-reveal>
    <p class="section-eyebrow">How this site runs</p>
    <h2>Small surface area, visible operations, automated delivery.</h2>
    <p class="section-intro">
      This site is intentionally compact. It exists to show delivery workflow,
      operational visibility, and a preference for simple, inspectable systems.
    </p>
  </div>
  <div class="container">
    <div class="dashboard-wrapper">
      <div class="dashboard-row" data-reveal>
        <div class="dashboard-card github-card dashboard-card--spotlight">
          <a
            href={`https://github.com/${githubRepo}`}
            target="_blank"
            rel="noopener noreferrer"
            class="github-card-link"
          >
            <div class="github-card-content">
              <p class="dashboard-card__eyebrow">Repository</p>
              <h3>Source, workflows, and deploy history in one place.</h3>
              <p class="dashboard-card__body">
                The repo carries the Astro frontend, infrastructure definition,
                and deploy automation that publishes this site.
              </p>
              <img
                class="pipeline-badge"
                src={`https://github.com/${githubRepo}/actions/workflows/release_prod.yml/badge.svg`}
                alt="Webstack Workflow Status"
              />
              <div class="github-repo-button">
                <img src="/assets/social/github.png" alt="GitHub" />
                <span>Source Code</span>
              </div>
            </div>
          </a>
        </div>
        <Visits client:load />
        <div class="dashboard-card">
          <p class="dashboard-card__eyebrow">Runtime shape</p>
          <h3>Built static, delivered through AWS, kept easy to inspect.</h3>
          <ul class="dashboard-notes">
            <li>Astro frontend with a small React surface for live widgets.</li>
            <li>CloudFront and S3 for static delivery, Route53 and ACM for edge routing.</li>
            <li>Lightweight operational data published back into the frontend.</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .container {
    width: 100%;
    padding: 0;
    box-sizing: border-box;
  }

  .dashboard-wrapper {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    flex: 1 1 0;
    min-width: 0;
  }

  .dashboard-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
    width: 100%;
    align-items: stretch;
  }

  .dashboard-card {
    background: linear-gradient(
      180deg,
      rgba(22, 49, 39, 0.88) 0%,
      rgba(12, 27, 22, 0.96) 100%
    );
    border-radius: 1.25rem;
    padding: 1.5rem;
    max-width: none;
    min-width: 280px;
    min-height: 220px;
    width: 100%;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    position: relative;
    text-align: left;
    transition:
      background 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s ease;
    border: 1px solid var(--color-border-soft);
    overflow: hidden;
  }

  .dashboard-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at top right, rgba(35, 191, 160, 0.18), transparent 38%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.03), transparent 40%);
    pointer-events: none;
  }

  .dashboard-card:hover {
    background: var(--color-surface-2);
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
  }

  .pipeline-badge {
    height: 28px;
    object-fit: contain;
    margin: 0;
  }

  .github-repo-button img {
    width: 28px;
    height: 28px;
    object-fit: contain;
    display: inline-block;
  }

  .github-card {
    justify-content: center;
    min-width: 0;
    align-items: flex-start;
    text-align: left;
  }

  .github-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
    width: 100%;
    height: 100%;
  }

  .dashboard-card--data {
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .github-card-content {
    border: none;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    justify-content: center;
    position: relative;
    z-index: 1;
  }

  .github-repo-button {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 12px 20px;
    border-radius: 8px;
    background: var(--color-background-dark);
    color: var(--color-text);
    font-weight: 600;
    white-space: nowrap;
    font-size: 1rem;
    transition:
      background 0.2s ease,
      transform 0.2s ease;
  }

  .github-card-link:hover .github-repo-button {
    background: var(--color-surface-2);
    transform: translateY(-1px);
  }

  .dashboard-card__eyebrow {
    margin: 0;
    color: var(--color-heading);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .dashboard-card h3 {
    margin: 0;
    font-size: 1.3rem;
    color: var(--color-text);
    max-width: 18ch;
  }

  .dashboard-card__body {
    margin: 0;
    color: var(--color-text-soft);
  }

  .dashboard-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
    width: 100%;
    position: relative;
    z-index: 1;
  }

  .dashboard-card li {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: baseline;
    gap: 1rem;
    width: 100%;
    margin-bottom: 0.5rem;
    font-size: 1rem;
  }

  .dashboard-card strong {
    font-weight: 600;
    color: var(--color-heading);
    min-width: 0;
  }

  .dashboard-notes {
    display: grid;
    gap: 0.9rem;
    margin-top: 1.25rem;
  }

  .dashboard-notes li {
    grid-template-columns: 1fr;
    gap: 0;
    margin: 0;
    padding-left: 1rem;
    position: relative;
    color: var(--color-text-soft);
  }

  .dashboard-notes li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.7rem;
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 999px;
    background: var(--color-accent);
    box-shadow: 0 0 0 0.3rem rgba(35, 191, 160, 0.12);
  }

  .metric-value {
    font-weight: 700;
    color: var(--color-hover);
    font-variant-numeric: tabular-nums;
    justify-self: end;
    text-align: right;
    white-space: nowrap;
  }

  .dashboard-card small {
    margin-top: 1rem;
    font-size: 0.875rem;
    color: var(--color-text);
  }

  .dashboard-card--spotlight {
    grid-column: span 2;
  }

  .github-card-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
    border-radius: 1.25rem;
  }

  .dashboard-card:focus-within {
    box-shadow: var(--shadow-card-hover);
    border-color: var(--color-border-strong);
  }

  @media (max-width: 1000px) {
    .dashboard-wrapper {
      width: 100%;
    }

    .dashboard-row {
      grid-template-columns: 1fr;
    }

    .dashboard-card--spotlight {
      grid-column: auto;
    }

    .dashboard-card,
    .github-card {
      margin-left: auto;
      margin-right: auto;
      width: 100%;
      min-width: unset;
      max-width: unset;
    }
  }
</style>
