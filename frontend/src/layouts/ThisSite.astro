---
import Visits from "../components/Visits";

const { githubRepo } = Astro.props;
---

<section id="this-site">
  <div class="section-heading" data-reveal>
    <p class="section-eyebrow">How this site runs</p>
    <h2>Small surface area, automated delivery, visible operations.</h2>
    <p class="section-intro">
      A small working example of the engineering style I prefer: simple
      systems, clear ownership, and visible runtime behavior.
    </p>
  </div>

  <div class="site-story-grid" data-reveal>
    <div class="site-story-copy">
      <div class="architecture-card">
        <p class="dashboard-card__eyebrow">Architecture summary</p>
        <h3>About this site.</h3>
        <ul class="architecture-list">
          <li>
            <strong>Astro frontend</strong>
            <span>Static by default, with React only where it helps.</span>
          </li>
          <li>
            <strong>AWS edge delivery</strong>
            <span>S3 and CloudFront, with ACM and Route53 at the edge.</span>
          </li>
          <li>
            <strong>Terraform-managed infrastructure</strong>
            <span>Infrastructure defined alongside the application.</span>
          </li>
          <li>
            <strong>Operational feedback in the UI</strong>
            <span>Lightweight runtime data surfaced back in the UI.</span>
          </li>
        </ul>
      </div>

      <div class="architecture-card architecture-card--note">
        <p class="dashboard-card__eyebrow">Why it is built this way</p>
        <p class="dashboard-card__body">
          The same pattern scales well: low complexity, explicit delivery
          paths, and visible operations.
        </p>
      </div>
    </div>

    <div class="proof-column">
      <div class="proof-card-stack">
        <div class="dashboard-card github-card">
          <div class="github-card-content">
            <p class="dashboard-card__eyebrow">Repository</p>
            <h3>Source, workflows, and deploy history in one place.</h3>
            <p class="dashboard-card__body">
              Frontend, infrastructure, and deploy automation live together.
            </p>
            <div class="repo-badge-row">
              <a
                href={`https://github.com/${githubRepo}/releases`}
                target="_blank"
                rel="noopener noreferrer"
                class="github-card-link github-card-link--badge"
                aria-label="Open releases"
              >
                <img
                  class="pipeline-badge"
                  src={`https://img.shields.io/github/v/release/${githubRepo}?display_name=tag&label=Latest%20Release`}
                  alt="Latest release version"
                />
              </a>
              <a
                href={`https://github.com/${githubRepo}/actions/workflows/prod_infra_plan.yml`}
                target="_blank"
                rel="noopener noreferrer"
                class="github-card-link github-card-link--badge"
                aria-label="Open infra plan workflow"
              >
                <img
                  class="pipeline-badge"
                  src={`https://img.shields.io/github/actions/workflow/status/${githubRepo}/prod_infra_plan.yml?label=Infra%20Plan`}
                  alt="Infra plan workflow status"
                />
              </a>
              <a
                href={`https://github.com/${githubRepo}/actions/workflows/prod_infra_apply_from_plan.yml`}
                target="_blank"
                rel="noopener noreferrer"
                class="github-card-link github-card-link--badge"
                aria-label="Open infra apply workflow"
              >
                <img
                  class="pipeline-badge"
                  src={`https://img.shields.io/github/actions/workflow/status/${githubRepo}/prod_infra_apply_from_plan.yml?label=Infra%20Apply`}
                  alt="Infra apply workflow status"
                />
              </a>
              <a
                href={`https://github.com/${githubRepo}/actions/workflows/prod_code_deploy.yml`}
                target="_blank"
                rel="noopener noreferrer"
                class="github-card-link github-card-link--badge"
                aria-label="Open code deploy workflow"
              >
                <img
                  class="pipeline-badge"
                  src={`https://img.shields.io/github/actions/workflow/status/${githubRepo}/prod_code_deploy.yml?label=Code%20deploy`}
                  alt="Code deploy workflow status"
                />
              </a>
            </div>
            <a
              href={`https://github.com/${githubRepo}`}
              target="_blank"
              rel="noopener noreferrer"
              class="github-card-link github-card-link--button"
            >
              <div class="github-repo-button">
                <img src="/assets/social/github.png" alt="GitHub" />
                <span>Source Code</span>
              </div>
            </a>
          </div>
        </div>
        <Visits client:load />
      </div>
    </div>
  </div>
</section>

<style is:global>
  #this-site .section-heading h2 {
    max-width: none;
  }

  .site-story-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    gap: 1.25rem;
    width: 100%;
    align-items: start;
    position: relative;
    z-index: 1;
  }

  .site-story-copy,
  .proof-column,
  .proof-card-stack {
    display: grid;
    gap: 1.25rem;
  }

  .architecture-card {
    position: relative;
    padding: 1.5rem;
    border-radius: 1.25rem;
    border: 1px solid var(--color-border-soft);
    background:
      linear-gradient(180deg, rgba(22, 49, 39, 0.74) 0%, rgba(12, 27, 22, 0.9) 100%);
    overflow: hidden;
  }

  .architecture-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at top right, rgba(35, 191, 160, 0.12), transparent 35%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.02), transparent 45%);
    pointer-events: none;
  }

  .architecture-card > * {
    position: relative;
    z-index: 1;
  }

  .architecture-card h3 {
    margin: 0.2rem 0 0.75rem;
    max-width: 20ch;
  }

  .architecture-card--note {
    min-height: 0;
  }

  .architecture-card--note .dashboard-card__body {
    max-width: 32ch;
  }

  .architecture-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1rem;
  }

  .architecture-list li {
    display: grid;
    gap: 0.25rem;
    padding-left: 1rem;
    position: relative;
  }

  .architecture-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.7rem;
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    background: var(--color-accent-warm);
    box-shadow: 0 0 0 0.28rem rgba(244, 184, 96, 0.12);
  }

  .architecture-list strong {
    color: var(--color-heading);
  }

  .architecture-list span {
    color: var(--color-text-soft);
  }

  .dashboard-card {
    background: linear-gradient(
      180deg,
      rgba(22, 49, 39, 0.88) 0%,
      rgba(12, 27, 22, 0.96) 100%
    );
    border-radius: 1.25rem;
    padding: 1.5rem;
    max-width: none;
    min-width: 280px;
    min-height: 220px;
    width: 100%;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    position: relative;
    text-align: left;
    transition:
      background 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s ease;
    border: 1px solid var(--color-border-soft);
    overflow: hidden;
  }

  .dashboard-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at top right, rgba(35, 191, 160, 0.18), transparent 38%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.03), transparent 40%);
    pointer-events: none;
  }

  .dashboard-card:hover {
    background: var(--color-surface-2);
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
  }

  .repo-badge-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, max-content));
    gap: 0.65rem;
    align-items: center;
    justify-content: start;
  }

  .pipeline-badge {
    height: 28px;
    object-fit: contain;
    margin: 0 0 0.25rem;
    display: block;
  }

  .github-repo-button img {
    width: 24px;
    height: 24px;
    min-width: 24px;
    min-height: 24px;
    max-width: 24px;
    max-height: 24px;
    object-fit: contain;
    display: inline-block;
    flex: 0 0 24px;
  }

  .github-card {
    justify-content: center;
    min-width: 0;
    align-items: flex-start;
    text-align: left;
  }

  .github-card:hover {
    background: linear-gradient(
      180deg,
      rgba(22, 49, 39, 0.88) 0%,
      rgba(12, 27, 22, 0.96) 100%
    );
    box-shadow: none;
    transform: none;
  }

  .github-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
    -webkit-tap-highlight-color: transparent;
  }

  .github-card-link:focus {
    outline: none;
  }

  .github-card-link--badge {
    display: inline-flex;
    border-radius: 999px;
    transition:
      filter 0.2s ease,
      transform 0.2s ease;
  }

  .github-card-link--badge:hover {
    filter: brightness(1.08) saturate(1.05);
    transform: translateY(-2px);
  }

  .github-card-link--button {
    width: 100%;
  }

  .dashboard-card--data {
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  .dashboard-card--data:focus {
    outline: none;
  }

  .github-card-content {
    border: none;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    justify-content: center;
    position: relative;
    z-index: 1;
  }

  .github-repo-button {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    min-height: 56px;
    padding: 14px 18px;
    border-radius: 0.95rem;
    background: linear-gradient(
      135deg,
      rgba(11, 25, 20, 0.96) 0%,
      rgba(22, 49, 39, 0.94) 100%
    );
    color: var(--color-text);
    font-weight: 700;
    white-space: nowrap;
    font-size: 1.05rem;
    border: 1px solid rgba(185, 242, 200, 0.16);
    box-sizing: border-box;
    transition:
      background 0.2s ease,
      transform 0.2s ease,
      border-color 0.2s ease;
  }

  .github-card-link:hover .github-repo-button {
    background: linear-gradient(
      135deg,
      rgba(18, 40, 32, 0.98) 0%,
      rgba(36, 66, 56, 0.96) 100%
    );
    border-color: var(--color-border-strong);
    transform: translateY(-1px);
  }

  .dashboard-card__eyebrow {
    margin: 0;
    color: var(--color-heading);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .dashboard-card h3 {
    margin: 0;
    font-size: 1.3rem;
    color: var(--color-text);
    max-width: 18ch;
  }

  .dashboard-card__body {
    margin: 0;
    color: var(--color-text-soft);
  }

  .dashboard-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
    width: 100%;
    position: relative;
    z-index: 1;
  }

  .dashboard-card li {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: baseline;
    gap: 1rem;
    width: 100%;
    margin-bottom: 0.5rem;
    font-size: 1rem;
  }

  .dashboard-card strong {
    font-weight: 600;
    color: var(--color-heading);
    min-width: 0;
  }

  .dashboard-notes {
    display: grid;
    gap: 0.9rem;
    margin-top: 1.25rem;
  }

  .dashboard-notes li {
    grid-template-columns: 1fr;
    gap: 0;
    margin: 0;
    padding-left: 1rem;
    position: relative;
    color: var(--color-text-soft);
  }

  .dashboard-notes li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.7rem;
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 999px;
    background: var(--color-accent);
    box-shadow: 0 0 0 0.3rem rgba(35, 191, 160, 0.12);
  }

  .metric-value {
    font-weight: 700;
    color: var(--color-hover);
    font-variant-numeric: tabular-nums;
    justify-self: end;
    text-align: right;
    white-space: nowrap;
  }

  .dashboard-card small {
    margin-top: 1rem;
    font-size: 0.875rem;
    color: var(--color-text);
  }

  .proof-card-stack .dashboard-card {
    min-height: 0;
  }

  .github-card-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
    border-radius: 1.25rem;
  }

  .github-card-link--badge:focus-visible {
    border-radius: 999px;
  }

  .dashboard-card:focus-within {
    box-shadow: var(--shadow-card-hover);
    border-color: var(--color-border-strong);
  }

  @media (max-width: 1000px) {
    .site-story-grid {
      grid-template-columns: 1fr;
    }

    .repo-badge-row {
      grid-template-columns: 1fr;
    }

    .dashboard-card,
    .github-card {
      margin-left: auto;
      margin-right: auto;
      width: 100%;
      min-width: unset;
      max-width: unset;
    }

    .github-repo-button img {
      width: 22px;
      height: 22px;
      min-width: 22px;
      min-height: 22px;
      max-width: 22px;
      max-height: 22px;
      flex-basis: 22px;
    }
  }
</style>
