---
import Header from "../layouts/Header.astro";
import Footer from "../layouts/Footer.astro";
import ThisSite from "../layouts/ThisSite.astro";
import AboutMe from "../layouts/AboutMe.astro";
import Certifications from "../layouts/Certifications.astro";

const baseDomain = import.meta.env.DEV
  ? "local.chrispsheehan.com"
  : "chrispsheehan.com";
const githubRepo =
  import.meta.env.GITHUB_REPOSITORY ?? "chrispsheehan/chrispsheehan.com";
const githubProfile = "https://github.com/chrispsheehan";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{baseDomain}</title>
    <link rel="stylesheet" href="/styles.css" />
    <link rel="icon" type="image/png" href="/face.png" />
  </head>
  <body>
    <Header baseDomain={baseDomain} githubRepo={githubRepo} />

    <main class="home-shell">
      <section id="hero" class="hero-section">
        <div class="hero-copy" data-reveal>
          <p class="section-eyebrow">Senior Platform Engineer</p>
          <h1>Platforms and CI/CD built to help teams ship faster.</h1>
          <div class="cta-row">
            <a
              class="button-link button-link--icon"
              href="https://www.linkedin.com/in/chrispsheehan"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn"
            >
              <img src="/assets/social/linkedin.png" alt="" aria-hidden="true" />
            </a>
            <a
              class="button-link button-link--icon"
              href={githubProfile}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="GitHub"
            >
              <img src="/assets/social/github.png" alt="" aria-hidden="true" />
            </a>
            <a
              class="button-link button-link--icon"
              href="https://registry.terraform.io/namespaces/chrispsheehan"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Terraform Registry"
            >
              <img src="/assets/social/terraform.png" alt="" aria-hidden="true" />
            </a>
            <a
              class="button-link button-link--icon"
              href="https://www.credly.com/users/chris-sheehan.b081233e/badges/credly"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Credly"
            >
              <img src="/assets/social/credly.png" alt="" aria-hidden="true" />
            </a>
          </div>
        </div>

        <aside class="hero-panel" data-reveal>
          <div class="hero-panel-card hero-panel-card--accent">
            <p class="section-eyebrow">Working style</p>
            <h2>Delivery paths that stay reliable.</h2>
            <div class="hero-metrics">
              <div>
                <span class="hero-metric-label">Scope</span>
                <strong>Infrastructure, pipelines, and internal tooling</strong>
              </div>
              <div>
                <span class="hero-metric-label">Approach</span>
                <strong>Practical, modular automation</strong>
              </div>
              <div>
                <span class="hero-metric-label">Outcome</span>
                <strong>Scalable, maintainable solutions</strong>
              </div>
            </div>
          </div>
        </aside>
      </section>

      <AboutMe />

      <Certifications />

      <ThisSite githubRepo={githubRepo} />
    </main>

    <Footer baseDomain={baseDomain} />
  </body>
</html>
