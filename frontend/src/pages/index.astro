---
import Header from "../layouts/Header.astro";
import Footer from "../layouts/Footer.astro";
import ThisSite from "../layouts/ThisSite.astro";
import AboutMe from "../layouts/AboutMe.astro";
import Certifications from "../layouts/Certifications.astro";

const baseDomain = import.meta.env.DEV
  ? "local.chrispsheehan.com"
  : "chrispsheehan.com";
const githubRepo =
  import.meta.env.GITHUB_REPOSITORY ?? "chrispsheehan/chrispsheehan.com";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{baseDomain}</title>
    <link rel="stylesheet" href="/styles.css" />
    <link rel="icon" type="image/png" href="/face.png" />
  </head>
  <body>
    <Header baseDomain={baseDomain} />

    <main class="home-shell">
      <section id="hero" class="hero-section">
        <div class="hero-copy" data-reveal>
          <p class="section-eyebrow">Platform engineering for fast-moving teams</p>
          <h1>Building delivery systems that stay fast under pressure.</h1>
          <p class="hero-intro">
            AWS, Terraform, CI/CD, and internal tooling built to improve
            developer flow without lowering standards.
          </p>
          <div class="cta-row">
            <a
              class="button-link button-link--primary"
              href={`https://github.com/${githubRepo}`}
              target="_blank"
              rel="noopener noreferrer"
            >
              View Source
            </a>
            <a class="button-link" href="#this-site">See Runtime</a>
            <a class="button-link button-link--ghost" href="#certifications">
              Certifications
            </a>
          </div>
          <ul class="pill-list" aria-label="Core focus areas">
            <li class="pill">AWS Platform Delivery</li>
            <li class="pill">Terraform Architecture</li>
            <li class="pill">CI/CD Systems</li>
            <li class="pill">Observability and Tooling</li>
          </ul>
          <div class="profile-links" aria-label="External profiles">
            <a
              class="profile-link"
              href={`https://github.com/${githubRepo}`}
              target="_blank"
              rel="noopener noreferrer"
            >
              <img src="/assets/social/github.png" alt="" aria-hidden="true" />
              <span>GitHub</span>
            </a>
            <a
              class="profile-link"
              href="https://www.linkedin.com/in/chrispsheehan"
              target="_blank"
              rel="noopener noreferrer"
            >
              <img src="/assets/social/linkedin.png" alt="" aria-hidden="true" />
              <span>LinkedIn</span>
            </a>
            <a
              class="profile-link"
              href="https://registry.terraform.io/namespaces/chrispsheehan"
              target="_blank"
              rel="noopener noreferrer"
            >
              <img src="/assets/social/terraform.png" alt="" aria-hidden="true" />
              <span>Terraform</span>
            </a>
          </div>
        </div>

        <aside class="hero-panel" data-reveal>
          <div class="hero-panel-card hero-panel-card--accent">
            <p class="section-eyebrow">What I optimize for</p>
            <h2>Reliable releases and less delivery drag.</h2>
            <div class="hero-metrics">
              <div>
                <span class="hero-metric-label">Delivery</span>
                <strong>Guardrails over gatekeeping</strong>
              </div>
              <div>
                <span class="hero-metric-label">Infrastructure</span>
                <strong>Composable Terraform and AWS patterns</strong>
              </div>
              <div>
                <span class="hero-metric-label">Teams</span>
                <strong>Better defaults for everyday engineering work</strong>
              </div>
            </div>
          </div>
        </aside>
      </section>

      <AboutMe />

      <Certifications />

      <ThisSite githubRepo={githubRepo} />
    </main>

    <Footer baseDomain={baseDomain} />
  </body>
</html>
